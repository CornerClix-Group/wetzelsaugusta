# ─────────────────────────────────────────────────────────────────
# Supabase — copy this file to `.env` (which is git-ignored) and fill in.
# In production, set these on your host's environment-variable panel.
# (Lovable: Project Settings → Variables. Vercel/Netlify: Site Settings.)
#
# All three are baked into the client bundle at BUILD time (Vite's
# `import.meta.env.VITE_*`). If the deploy is missing any of them, the
# app will show a configuration-error screen instead of crashing.
# ─────────────────────────────────────────────────────────────────

# Your Supabase project ref (the subdomain before .supabase.co)
VITE_SUPABASE_PROJECT_ID="your-project-ref-here"

# Public anon key from Supabase → Settings → API.
# Safe to ship publicly; security relies on RLS, not on this being secret.
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# Full project URL (https://<project_id>.supabase.co)
VITE_SUPABASE_URL="https://your-project-ref-here.supabase.co"
